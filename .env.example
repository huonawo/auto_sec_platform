# AutoSec Platform Environment Variables
# Copy this file to .env and fill in the values before running docker-compose up.

# Redis password — required by backend, worker, and orchestrator.
# Must match across all services. Generate a strong password for production.
REDIS_PASSWORD=change_me_to_a_strong_password

# Optional local development override for result JSON files.
# Docker defaults to /workspace/output; Windows local runs can point to .\output.
# AUTOSEC_OUTPUT_DIR=D:\auto_sec_platform\output
